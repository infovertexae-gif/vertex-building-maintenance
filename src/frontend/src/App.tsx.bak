            transition={{ duration: 0.6 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <p
              className="text-sm font-semibold uppercase tracking-widest mb-3"
              style={{ color: "oklch(var(--gold))" }}
            >
              Our Advantage
            </p>
            <h2 className="font-display text-4xl lg:text-5xl font-bold mb-6 text-foreground">
              Why Choose Vertex?
            </h2>
            <div
              className="h-1 w-16 mx-auto mb-6 rounded"
              style={{ backgroundColor: "oklch(var(--gold))" }}
            />
            <p className="text-foreground/60 text-lg max-w-2xl mx-auto">
              We combine technical expertise with exceptional service delivery
              so your property stays in peak condition.
            </p>
          </motion.div>

          <div className="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
            {whyUs.map((item, i) => (
              <motion.div
                key={item.title}
                initial={{ opacity: 0, y: 30 }}
                whileInView={{ opacity: 1, y: 0 }}
                transition={{ duration: 0.5, delay: i * 0.1 }}
                viewport={{ once: true }}
                whileHover={{ scale: 1.04 }}
                className="rounded-2xl p-7 text-center"
                style={{
                  backgroundColor: "oklch(var(--navy-light) / 0.6)",
                  border: "1px solid oklch(var(--foreground) / 0.12)",
                }}
              >
                <div
                  className="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5"
                  style={{ backgroundColor: "oklch(var(--gold) / 0.15)" }}
                >
                  <item.icon
                    size={28}
                    style={{ color: "oklch(var(--gold))" }}
                  />
                </div>
                <h3 className="font-display font-bold text-lg text-foreground mb-3">
                  {item.title}
                </h3>
                <p className="text-foreground/60 text-sm leading-relaxed">
                  {item.desc}
                </p>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* ===== PROJECTS ===== */}
      <section id="projects" className="py-24 bg-white">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <p
              className="text-sm font-semibold uppercase tracking-widest mb-3"
              style={{ color: "oklch(var(--gold))" }}
            >
              Our Work
            </p>
            <h2
              className="font-display text-4xl lg:text-5xl font-bold mb-6"
              style={{ color: "oklch(var(--gold))" }}
            >
              Featured Projects
            </h2>
            <div
              className="h-1 w-16 mx-auto mb-6 rounded"
              style={{ backgroundColor: "oklch(var(--gold))" }}
            />
            <p className="text-muted-foreground text-lg max-w-2xl mx-auto">
              A selection of our recent maintenance and renovation projects
              across the UAE.
            </p>
          </motion.div>

          <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-7">
            {projects.map((proj, i) => (
              <motion.div
                key={proj.title}
                data-ocid={`projects.item.${i + 1}`}
                initial={{ opacity: 0, scale: 0.96 }}
                whileInView={{ opacity: 1, scale: 1 }}
                transition={{ duration: 0.5, delay: (i % 3) * 0.1 }}
                viewport={{ once: true }}
                className="group relative rounded-2xl overflow-hidden shadow-xs cursor-default"
                style={{ aspectRatio: "4/3" }}
              >
                <img
                  src={proj.img}
                  alt={proj.title}
                  className="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                {/* Overlay */}
                <div
                  className="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                  style={{
                    background:
                      "linear-gradient(to top, oklch(var(--navy-dark) / 0.95) 0%, transparent 60%)",
                  }}
                >
                  <span
                    className="text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full self-start mb-3"
                    style={{
                      backgroundColor: "transparent",
                      border: "1px solid oklch(1 0 0 / 0.7)",
                      color: "white",
                    }}
                  >
                    {proj.category}
                  </span>
                  <h3 className="font-display text-xl font-bold text-foreground">
                    {proj.title}
                  </h3>
                  <p className="text-foreground/70 text-sm mt-1">
                    {proj.location}
                  </p>
                </div>
                {/* Permanent badge */}
                <div className="absolute top-4 left-4 opacity-100 group-hover:opacity-0 transition-opacity duration-300">
                  <span
                    className="text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full"
                    style={{
                      backgroundColor: "transparent",
                      border: "1px solid oklch(1 0 0 / 0.7)",
                      color: "white",
                    }}
                  >
                    {proj.category}
                  </span>
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* ===== CONTACT ===== */}
      <section id="contact" className="py-24 bg-white">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <p
              className="text-sm font-semibold uppercase tracking-widest mb-3"
              style={{ color: "oklch(var(--gold))" }}
            >
              Get In Touch
            </p>
            <h2
              className="font-display text-4xl lg:text-5xl font-bold mb-6"
              style={{ color: "oklch(var(--navy))" }}
            >
              Request a Free Quote
            </h2>
            <div
              className="h-1 w-16 mx-auto mb-6 rounded"
              style={{ backgroundColor: "oklch(var(--gold))" }}
            />
            <p className="text-muted-foreground text-lg max-w-2xl mx-auto">
              Fill in your details and our team will get back to you within 2
              hours.
            </p>
          </motion.div>

          <div className="grid lg:grid-cols-2 gap-16">
            {/* Form */}
            <motion.div
              initial={{ opacity: 0, x: -30 }}
              whileInView={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.6 }}
              viewport={{ once: true }}
            >
              <form onSubmit={handleSubmit} className="space-y-5">
                <div>
                  <Label htmlFor="name" className="font-semibold mb-2 block">
                    Full Name *
                  </Label>
                  <Input
                    id="name"
                    data-ocid="contact.name.input"
                    placeholder="Ahmed Al Mansouri"
                    value={formData.name}
                    onChange={(e) =>
                      setFormData((p) => ({ ...p, name: e.target.value }))
                    }
                    required
                  />
                </div>
                <div className="grid sm:grid-cols-2 gap-5">
                  <div>
                    <Label htmlFor="email" className="font-semibold mb-2 block">
                      Email Address *
                    </Label>
                    <Input
                      id="email"
                      type="email"
                      data-ocid="contact.email.input"
                      placeholder="ahmed@company.ae"
                      value={formData.email}
                      onChange={(e) =>
                        setFormData((p) => ({ ...p, email: e.target.value }))
                      }
                      required
                    />
                  </div>
                  <div>
                    <Label htmlFor="phone" className="font-semibold mb-2 block">
                      Phone Number *
                    </Label>
                    <Input
                      id="phone"
                      type="tel"
                      data-ocid="contact.phone.input"
                      placeholder="+971 50 000 0000"
                      value={formData.phone}
                      onChange={(e) =>
                        setFormData((p) => ({ ...p, phone: e.target.value }))
                      }
                      required
                    />
                  </div>
                </div>
                <div>
                  <Label htmlFor="service" className="font-semibold mb-2 block">
                    Service Required
                  </Label>
                  <Select
                    value={formData.service}
                    onValueChange={(v) =>
                      setFormData((p) => ({ ...p, service: v }))
                    }
                  >
                    <SelectTrigger
                      data-ocid="contact.service.select"
                      id="service"
                    >
                      <SelectValue placeholder="Select a service..." />
                    </SelectTrigger>
                    <SelectContent>
                      {services.map((s) => (
                        <SelectItem key={s.title} value={s.title}>
                          {s.title}
                        </SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                </div>
                <div>
                  <Label htmlFor="message" className="font-semibold mb-2 block">
                    Message *
                  </Label>
                  <Textarea
                    id="message"
                    data-ocid="contact.message.textarea"
                    placeholder="Please describe your maintenance requirements..."
                    rows={5}
                    value={formData.message}
                    onChange={(e) =>
                      setFormData((p) => ({ ...p, message: e.target.value }))
                    }
                    required
                  />
                </div>

                {submitInquiry.isSuccess && (
                  <div
                    data-ocid="contact.success_state"
                    className="rounded-lg p-4 text-sm font-medium flex items-center gap-2"
                    style={{
                      backgroundColor: "oklch(0.9 0.1 145 / 0.15)",
                      color: "oklch(0.45 0.15 145)",
                      border: "1px solid oklch(0.7 0.15 145 / 0.3)",
                    }}
                  >
                    <CheckCircle2 size={16} />
                    Inquiry submitted successfully! We'll contact you shortly.
                  </div>
                )}

                {submitInquiry.isError && (
                  <div
                    data-ocid="contact.error_state"
                    className="rounded-lg p-4 text-sm font-medium"
                    style={{
                      backgroundColor: "oklch(0.9 0.1 25 / 0.15)",
                      color: "oklch(0.45 0.2 25)",
                      border: "1px solid oklch(0.7 0.15 25 / 0.3)",
                    }}
                  >
                    Something went wrong. Please try again or call us directly.
                  </div>
                )}

                <Button
                  type="submit"
                  data-ocid="contact.submit_button"
                  disabled={submitInquiry.isPending}
                  size="lg"
                  className="w-full font-bold text-base py-6 transition-transform hover:scale-[1.02]"
                  style={{
                    backgroundColor: "oklch(var(--gold))",
                    color: "oklch(var(--foreground))",
                  }}
                >
                  {submitInquiry.isPending ? (
                    <>
                      <Loader2 className="mr-2 h-5 w-5 animate-spin" />
                      <span data-ocid="contact.loading_state">
                        Submitting...
                      </span>
                    </>
                  ) : (
                    "Submit Inquiry"
                  )}
                </Button>
              </form>
            </motion.div>

            {/* Contact Info */}
            <motion.div
              initial={{ opacity: 0, x: 30 }}
              whileInView={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.6 }}
              viewport={{ once: true }}
              className="space-y-6"
            >
              {[
                {
                  icon: Phone,
                  title: "Phone",
                  lines: ["+971 52 939 7284", "Emergency: +971 52 221 7216"],
                },
                {
                  icon: Mail,
                  title: "Email",
                  lines: ["info.vertex.ae@gmail.com", "opr.vertex@gmail.com"],
                },
                {
                  icon: MapPin,
                  title: "Address",
                  lines: [
                    "Head Office: Office No. 22, Al Mairid,",
                    "Ahmed Bin Majid Street, RAK",
                    "Branch Office: Office No. 110,",
                    "Al Muraqqabat, Deira Dubai",
                  ],
                },
                {
                  icon: Clock,
                  title: "Working Hours",
                  lines: [
                    "Mon – Sat: 8:00 AM – 8:00 PM",
                    "Emergency: 24/7 Available",
                  ],
                },
              ].map((info) => (
                <div
                  key={info.title}
                  className="flex gap-5 p-6 rounded-2xl"
                  style={{
                    backgroundColor: "oklch(0.96 0 0)",
                    border: "1px solid oklch(var(--border))",
                  }}
                >
                  <div
                    className="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                    style={{ backgroundColor: "oklch(var(--navy))" }}
                  >
                    <info.icon
                      size={20}
                      style={{ color: "oklch(var(--gold))" }}
                    />
                  </div>
                  <div>
                    <h4
                      className="font-semibold mb-1"
                      style={{ color: "oklch(var(--navy))" }}
                    >
                      {info.title}
                    </h4>
                    {info.lines.map((line) => (
                      <p key={line} className="text-muted-foreground text-sm">
                        {line}
                      </p>
                    ))}
                  </div>
                </div>
              ))}

              {/* Maps */}
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <p
                    className="text-sm font-bold mb-2"
                    style={{ color: "oklch(var(--navy))" }}
                  >
                    Head Office – RAK
                  </p>
                  <div className="rounded-2xl overflow-hidden">
                    <iframe
                      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3604.5!2d55.7804!3d25.6691!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjXCsDQwJzA4LjgiTiA1NcKwNDYnNTAuNCJF!5e0!3m2!1sen!2sae!4v1234567890"
                      width="100%"
                      height="200"
                      style={{ border: 0 }}
                      loading="lazy"
                      title="Head Office RAK"
                      className="rounded-xl"
                    />
                  </div>
                </div>
                <div>
                  <p
                    className="text-sm font-bold mb-2"
                    style={{ color: "oklch(var(--navy))" }}
                  >
                    Branch Office – Deira Dubai
                  </p>
                  <div className="rounded-2xl overflow-hidden">
                    <iframe
                      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3607.8!2d55.3273!3d25.2697!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3e5f5d3f3f3f3f3f%3A0x0!2zMjXCsDE2JzExLjAiTiA1NcKwMTknMzguMyJF!5e0!3m2!1sen!2sae!4v1234567890"
                      width="100%"
                      height="200"
                      style={{ border: 0 }}
                      loading="lazy"
                      title="Branch Office Deira Dubai"
                      className="rounded-xl"
                    />
                  </div>
                </div>
              </div>
            </motion.div>
          </div>
        </div>
      </section>

      {/* ===== FOOTER ===== */}
      <footer style={{ backgroundColor: "oklch(var(--navy))" }}>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
            {/* Brand */}
            <div className="lg:col-span-1">
              <div className="flex items-center gap-2 mb-4">
                <img
                  src="/assets/generated/VERTEX-LOGO-transparent.png"
                  alt="Vertex Building Maintenance"
                  style={{
                    height: "48px",
                    width: "auto",
                    filter:
                      "contrast(1.6) brightness(1.15) drop-shadow(0 2px 6px rgba(0,0,0,0.6)) saturate(1.2)",
                    imageRendering: "crisp-edges",
                  }}
                />
                <span className="font-display text-xl font-bold text-foreground">
                  Vertex Building Maintenance
                </span>
              </div>
              <p className="text-foreground/50 text-sm mb-1 font-medium italic">
                Building Excellence, Delivering Trust
              </p>
              <p className="text-foreground/40 text-sm mt-4 leading-relaxed">
                UAE's trusted partner in building maintenance and facilities
                management since 2023.
              </p>
              <div className="flex gap-3 mt-6">
                {[
                  { Icon: Facebook, label: "Facebook" },
                  { Icon: Twitter, label: "Twitter" },
                  { Icon: Linkedin, label: "LinkedIn" },
                  { Icon: Instagram, label: "Instagram" },
                ].map(({ Icon, label }) => (
                  <button
                    type="button"
                    key={label}
                    aria-label={label}
                    className="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                    style={{
                      backgroundColor: "oklch(var(--gold) / 0.15)",
                      color: "oklch(var(--gold))",
                    }}
                  >
                    <Icon size={16} />
                  </button>
                ))}
              </div>
            </div>

            {/* Quick Links */}
            <div>
              <h4 className="font-display font-bold text-foreground mb-5">
                Quick Links
              </h4>
              <ul className="space-y-3">
                {[
                  { label: "Home", id: "home" },
                  { label: "About Us", id: "about" },
                  { label: "Our Services", id: "services" },
                  { label: "Projects", id: "projects" },
                  { label: "Contact", id: "contact" },
                ].map((link) => (
                  <li key={link.id}>
                    <button
                      type="button"
                      onClick={() => scrollTo(link.id)}
                      className="text-foreground/50 hover:text-foreground text-sm transition-colors flex items-center gap-2 group"
                    >
                      <ChevronRight
                        size={12}
                        className="group-hover:translate-x-1 transition-transform"
                        style={{ color: "oklch(var(--gold))" }}
                      />
                      {link.label}
                    </button>
                  </li>
                ))}
              </ul>
            </div>

            {/* Services */}
            <div>
              <h4 className="font-display font-bold text-foreground mb-5">
                Services
              </h4>
              <ul className="space-y-3">
                {services.slice(0, 6).map((s) => (
                  <li key={s.title}>
                    <button
                      type="button"
                      onClick={() => scrollTo("services")}
                      className="text-foreground/50 hover:text-foreground text-sm transition-colors flex items-center gap-2 group"
                    >
                      <ChevronRight
                        size={12}
                        className="group-hover:translate-x-1 transition-transform"
                        style={{ color: "oklch(var(--gold))" }}
                      />
                      {s.title}
                    </button>
                  </li>
                ))}
              </ul>
            </div>

            {/* Contact */}
            <div>
              <h4 className="font-display font-bold text-foreground mb-5">
                Contact Info
              </h4>
              <ul className="space-y-4">
                <li className="flex gap-3">
                  <Phone
                    size={16}
                    style={{
                      color: "oklch(var(--gold))",
                      marginTop: 2,
                      flexShrink: 0,
                    }}
                  />
                  <span className="text-foreground/50 text-sm">
                    +971 52 939 7284
                  </span>
                </li>
                <li className="flex gap-3">
                  <Mail
                    size={16}
                    style={{
                      color: "oklch(var(--gold))",
                      marginTop: 2,
                      flexShrink: 0,
                    }}
                  />
                  <span className="text-foreground/50 text-sm">
                    info.vertex.ae@gmail.com
                  </span>
                </li>
                <li className="flex gap-3">
                  <MapPin
                    size={16}
                    style={{
                      color: "oklch(var(--gold))",
                      marginTop: 2,
                      flexShrink: 0,
                    }}
                  />
                  <span className="text-foreground/50 text-sm">
                    Head Office: Al Mairid, RAK | Branch: Al Muraqqabat, Deira
                    Dubai
                  </span>
                </li>
                <li className="flex gap-3">
                  <Clock
                    size={16}
                    style={{
                      color: "oklch(var(--gold))",
                      marginTop: 2,
                      flexShrink: 0,
                    }}
                  />
                  <span className="text-foreground/50 text-sm">
                    Mon–Sat: 8:00 AM – 8:00 PM
                  </span>
                </li>
              </ul>
            </div>
          </div>

          {/* Bottom bar */}
          <div
            className="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm"
            style={{ borderTop: "1px solid oklch(var(--foreground) / 0.12)" }}
          >
            <p className="text-foreground/40">
              &copy; {new Date().getFullYear()} Vertex Building Maintenance. All
              rights reserved.
            </p>
            <p className="text-foreground/30">
              Built with ❤ using{" "}
              <a
                href={`https://caffeine.ai?utm_source=caffeine-footer&utm_medium=referral&utm_content=${encodeURIComponent(window.location.hostname)}`}
                target="_blank"
                rel="noopener noreferrer"
                className="text-white/50 hover:text-white transition-colors underline underline-offset-2"
              >
                caffeine.ai
              </a>
            </p>
          </div>
        </div>
      </footer>
    </div>
  );
}
